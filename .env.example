# ── Core ──────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://...
ANTHROPIC_API_KEY=sk-ant-...
NODE_ENV=development
PORT=3001
BETLY_BASE_URL=https://betly.gg

# ── Pipeline: Twitter / X API ────────────────────────────────
TWITTER_BEARER_TOKEN=         # Twitter API v2 Bearer (read)
TWITTER_APP_ACCESS_TOKEN=     # Twitter API v2 OAuth (write/post)

# ── Pipeline: Reddit API ─────────────────────────────────────
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=

# ── Pipeline: Postiz (social scheduler) ──────────────────────
POSTIZ_API_KEY=
POSTIZ_API_URL=https://app.postiz.com/api/v1

# ── Pipeline: Telegram Bot ───────────────────────────────────
TELEGRAM_BOT_TOKEN=           # from @BotFather
TELEGRAM_CHANNEL_ID=          # e.g. @betly_markets or -100123456789
