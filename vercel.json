{
  "version": 2,
  "crons": [
    { "path": "/api/cron/sync-polymarket", "schedule": "0 8 * * *" },
    { "path": "/api/cron/resolve-markets", "schedule": "0 12 * * *" }
  ],
  "builds": [
    {
      "src": "index.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "web/dist/**",
          "src/**",
          "db/**",
          "config/**"
        ]
      }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "/index.js" }
  ]
}
